                                </div>
                                <input type="range" id="slider-claims" min="1" max="100" value="20" oninput="syncSlider('claims')" class="w-full mt-3 accent-indigo-600 bg-slate-200 h-1 rounded-lg appearance-none cursor-pointer">
                            </div>

                            <!-- 独立权利要求数 -->
                            <div class="bg-slate-50/50 p-4 rounded-xl border border-slate-100">
                                <div class="flex justify-between items-center mb-2">
                                    <label class="text-xs font-bold text-slate-500 uppercase">独立权利要求数</label>
                                    <span class="text-[11px] bg-indigo-100 text-indigo-700 px-1.5 py-0.5 rounded font-bold" id="val-disp-indClaims">3 项</span>
                                </div>
                                <div class="relative rounded-lg shadow-sm">
                                    <input type="number" id="param-indClaims" value="3" min="1" max="20" oninput="calculateAll()"
